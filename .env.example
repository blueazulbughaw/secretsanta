FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET=change-me-too
OTP_PEPPER=change-me-three
# Leave DATABASE_URL unset to use local SQLite for instant testing.
# MySQL example: mysql+pymysql://gc_dev:password@localhost/giftcircle
DATABASE_URL=
# Leave MAIL_SERVER empty in dev: OTP codes print to the console instead.
MAIL_SERVER=
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USERNAME=
MAIL_PASSWORD=
# Leave TWILIO_* empty in dev: OTP codes print to the console instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Comma-separated E.164 phone numbers allowed to create new families.
# Leave empty in dev to allow anyone (convenient for testing); set this
# in production to lock family creation down to yourself.
APP_ADMIN_PHONES=
APP_BASE_URL=http://localhost:5000
