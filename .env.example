FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET=change-me-too
OTP_PEPPER=change-me-three
# Leave DATABASE_URL unset to use local SQLite for instant testing.
# MySQL example: mysql+pymysql://gc_dev:password@localhost/giftcircle
DATABASE_URL=
# Leave MAIL_SERVER empty in dev: OTP codes print to the console instead.
MAIL_SERVER=
MAIL_PORT=465
MAIL_USE_SSL=true
MAIL_USERNAME=
MAIL_PASSWORD=
# Leave TWILIO_* empty in dev: OTP codes print to the console instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Master key for the hidden /ss-admin route (username + this key logs in as,
# or creates, an admin account, bypassing SMS/password). Leave empty to
# disable the route. Use a long, random value.
ADMIN_BACKDOOR_PASSWORD=
APP_BASE_URL=http://localhost:5000
